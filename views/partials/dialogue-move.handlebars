<form action="@move" method="post">
	<div id="move" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header bg-light">
					<h5 class="modal-title">Move selected files</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<p class="multi-files-summary text-muted mb-2"></p>
					<ul class="list-group multi-files mb-3"></ul>
					<input type="hidden" name="files" value="" class="multi-files-value" />
					<div class="mb-3">
						<label class="form-label" for="move-target">Destination folder (relative path)</label>
						<input class="form-control" type="text" name="target" id="move-target" placeholder="subdir/" />
					</div>
				</div>
				<div class="modal-footer bg-light">
					<button type="reset" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
					<button type="submit" class="btn btn-primary">Move</button>
				</div>
			</div>
		</div>
	</div>
</form>