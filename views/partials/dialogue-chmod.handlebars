<form action="@chmod" method="post">
	<div id="chmod" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header bg-light">
					<h5 class="modal-title">Change permissions</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<p class="multi-files-summary text-muted mb-2"></p>
					<ul class="list-group multi-files mb-3"></ul>
					<input type="hidden" name="files" value="" class="multi-files-value" />
					<div class="mb-3">
						<label class="form-label" for="chmod-mode">Mode (octal, e.g. <code>644</code> or <code>755</code>)</label>
						<input class="form-control" type="text" name="mode" id="chmod-mode" placeholder="755" pattern="[0-7]{3,4}" />
					</div>
					<div class="row">
						<div class="col">
							<button type="button" class="btn btn-outline-secondary w-100 chmod-preset" data-mode="644">644</button>
						</div>
						<div class="col">
							<button type="button" class="btn btn-outline-secondary w-100 chmod-preset" data-mode="755">755</button>
						</div>
						<div class="col">
							<button type="button" class="btn btn-outline-secondary w-100 chmod-preset" data-mode="600">600</button>
						</div>
						<div class="col">
							<button type="button" class="btn btn-outline-secondary w-100 chmod-preset" data-mode="700">700</button>
						</div>
					</div>
				</div>
				<div class="modal-footer bg-light">
					<button type="reset" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
					<button type="submit" class="btn btn-primary">Apply</button>
				</div>
			</div>
		</div>
	</div>
</form>